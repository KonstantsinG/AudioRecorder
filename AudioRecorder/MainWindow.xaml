<Window x:Class="AudioRecorder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AudioRecorder" d:DataContext="{d:DesignInstance Type=local:DeviceControl}"
        mc:Ignorable="d" WindowStyle="None"
        Title="AudioRecorder" Height="540" Width="960"
        Background="{DynamicResource Accent}"
        Loaded="Window_Loaded">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30" ResizeBorderThickness="6"
                      GlassFrameThickness="5" UseAeroCaptionButtons="True"
                      CornerRadius="10"/>
    </WindowChrome.WindowChrome>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Rectangle Grid.RowSpan="2" Margin="2" Fill="{DynamicResource Dark1}"
                   RadiusX="5" RadiusY="5"/>

        <Grid Grid.Row="0" VerticalAlignment="Center">

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="10,0">

                <Ellipse Height="10" Width="10" Fill="LawnGreen" Margin="5,0"
                         WindowChrome.IsHitTestVisibleInChrome="True"
                         MouseLeftButtonDown="GreenCircle_MouseLeftButtonDown"/>

                <Ellipse Height="10" Width="10" Fill="Yellow" Margin="5,0"
                         WindowChrome.IsHitTestVisibleInChrome="True"
                         MouseLeftButtonDown="YellowCircle_MouseLeftButtonDown"/>

                <Ellipse Height="10" Width="10" Fill="OrangeRed" Margin="5,0"
                         WindowChrome.IsHitTestVisibleInChrome="True"
                         MouseLeftButtonDown="RedCircle_MouseLeftButtonDown"/>

            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                        Margin="15,0" VerticalAlignment="Center">

                <Ellipse Height="5" Width="5" Fill="White" Margin="5"/>

                <TextBlock Text="AudioRecorder" Foreground="{DynamicResource Light0}"
                           FontWeight="Light"/>

            </StackPanel>

        </Grid>

        <Grid Grid.Row="1" Background="{DynamicResource Dark2}" Margin="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="370"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Background="{DynamicResource Dark1}"
                  Margin="5">

                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>

                <Grid Panel.ZIndex="10" Grid.RowSpan="2" Visibility="Collapsed"
                      Margin="0,0,0,40" IsHitTestVisible="False" x:Name="countdownPanel">

                    <Rectangle Width="Auto" Height="Auto" Fill="#A5131313"
                               Stroke="#FF262626" StrokeThickness="2"/>

                    <TextBlock HorizontalAlignment="Center" x:Name="countdownTBlock"
                               VerticalAlignment="Center" Text="3" FontSize="100"
                               Foreground="{DynamicResource Light1}"
                               FontWeight="Medium"/>

                </Grid>

                <Grid Grid.Row="0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <StackPanel Margin="25,0,0,0" VerticalAlignment="Bottom"
                                    Orientation="Horizontal">

                            <TextBlock Foreground="{DynamicResource Light1}"
                                       Text="Available devices"  FontWeight="Light"/>

                            <Button Width="15" Height="15" Margin="10,0"
                                    Click="RefreshDevices_Click"
                                    Cursor="Hand"
                                    Focusable="False">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Image x:Name="icon" 
                                               Source="/Icons/refresh.png" 
                                               Width="15" Height="15"
                                               RenderTransformOrigin="0.5,0.5">
                                            <Image.RenderTransform>
                                                <TransformGroup>
                                                    <RotateTransform x:Name="rotation" Angle="0"/>
                                                    <ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1"/>
                                                </TransformGroup>
                                            </Image.RenderTransform>
                                        </Image>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="rotation"
                                                                             Storyboard.TargetProperty="Angle"
                                                                             To="-180"
                                                                             Duration="0:0:0.15"/>
                                                            <DoubleAnimation Storyboard.TargetName="scale"
                                                                             Storyboard.TargetProperty="ScaleX"
                                                                             To="0.7"
                                                                             Duration="0:0:0.1"/>
                                                            <DoubleAnimation Storyboard.TargetName="scale"
                                                                             Storyboard.TargetProperty="ScaleY"
                                                                             To="0.7"
                                                                             Duration="0:0:0.1"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="rotation"
                                                                             Storyboard.TargetProperty="Angle"
                                                                             To="0"
                                                                             Duration="0:0:0.1"/>
                                                            <DoubleAnimation Storyboard.TargetName="scale"
                                                                             Storyboard.TargetProperty="ScaleX"
                                                                             To="1"
                                                                             Duration="0:0:0.1"/>
                                                            <DoubleAnimation Storyboard.TargetName="scale"
                                                                             Storyboard.TargetProperty="ScaleY"
                                                                             To="1"
                                                                             Duration="0:0:0.1"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                        </StackPanel>

                        <Rectangle Width="Auto" Height="Auto" Margin="10,5,5,0"
                                   Fill="{DynamicResource Dark1}" StrokeThickness="2"
                                   Stroke="{DynamicResource Dark3}"
                                   RadiusX="5" RadiusY="5" Grid.Row="1"/>

                        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Hidden">
                            <ItemsControl Margin="20,15,15,0" x:Name="devicesPanel">



                            </ItemsControl>
                        </ScrollViewer>

                    </Grid>

                    <Grid Grid.Column="1">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <StackPanel Margin="25,0,0,0" VerticalAlignment="Bottom"
                                    Orientation="Horizontal">

                            <TextBlock Foreground="{DynamicResource Light1}"
                                       Text="Running processes"  FontWeight="Light">
                                <TextBlock.ToolTip>
                                    <ToolTip Background="{DynamicResource Dark1}" 
                                             BorderBrush="{DynamicResource Dark3}" 
                                             BorderThickness="1">
                                        <StackPanel Margin="3">
                                            <TextBlock Text="White - active" 
                                                       FontSize="10"
                                                       Foreground="{DynamicResource Light0}"/>
                                            <TextBlock Text="Gray - muted" 
                                                       FontSize="10"
                                                       Foreground="{DynamicResource Light2}"/>
                                            <TextBlock Text="Blue - system" 
                                                       FontSize="10"
                                                       Foreground="CornflowerBlue"/>
                                        </StackPanel>
                                    </ToolTip>
                                </TextBlock.ToolTip>
                            </TextBlock>

                            <Button Width="15" Height="15" Margin="10,0"
                                    Click="RefreshProcesses_Click"
                                    Cursor="Hand"
                                    Focusable="False">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Image x:Name="icon" 
                                               Source="/Icons/refresh.png" 
                                               Width="15" Height="15"
                                               RenderTransformOrigin="0.5,0.5">
                                            <Image.RenderTransform>
                                                <TransformGroup>
                                                    <RotateTransform x:Name="rotation" Angle="0"/>
                                                    <ScaleTransform x:Name="scale" ScaleX="1" ScaleY="1"/>
                                                </TransformGroup>
                                            </Image.RenderTransform>
                                        </Image>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Trigger.EnterActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="rotation"
                                                                             Storyboard.TargetProperty="Angle"
                                                                             To="-180"
                                                                             Duration="0:0:0.15"/>
                                                            <DoubleAnimation Storyboard.TargetName="scale"
                                                                             Storyboard.TargetProperty="ScaleX"
                                                                             To="0.7"
                                                                             Duration="0:0:0.1"/>
                                                            <DoubleAnimation Storyboard.TargetName="scale"
                                                                             Storyboard.TargetProperty="ScaleY"
                                                                             To="0.7"
                                                                             Duration="0:0:0.1"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.EnterActions>
                                                <Trigger.ExitActions>
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetName="rotation"
                                                                             Storyboard.TargetProperty="Angle"
                                                                             To="0"
                                                                             Duration="0:0:0.1"/>
                                                            <DoubleAnimation Storyboard.TargetName="scale"
                                                                             Storyboard.TargetProperty="ScaleX"
                                                                             To="1"
                                                                             Duration="0:0:0.1"/>
                                                            <DoubleAnimation Storyboard.TargetName="scale"
                                                                             Storyboard.TargetProperty="ScaleY"
                                                                             To="1"
                                                                             Duration="0:0:0.1"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </Trigger.ExitActions>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                        </StackPanel>

                        <Rectangle Width="Auto" Height="Auto" Margin="5,5,10,0"
                                   Fill="{DynamicResource Dark1}" StrokeThickness="2"
                                   Stroke="{DynamicResource Dark3}"
                                   RadiusX="5" RadiusY="5" Grid.Row="1"/>

                        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Hidden">
                            <ItemsControl Margin="15,10,10,10" x:Name="processesPanel">



                            </ItemsControl>
                        </ScrollViewer>

                    </Grid>

                </Grid>

                <Grid Grid.Row="1" Margin="20,10" Panel.ZIndex="15">

                    <Ellipse Height="12" Width="12" Stroke="White" x:Name="recordingIcon1"
                             HorizontalAlignment="Left" VerticalAlignment="Top"
                             StrokeThickness="1"/>

                    <Ellipse Height="6" Width="6" Fill="White" x:Name="recordingIcon2"
                             HorizontalAlignment="Left" VerticalAlignment="Top"
                             Margin="3,3,0,0"/>

                    <TextBlock Foreground="{DynamicResource Light1}"
                               Text="Ready"  FontWeight="Light"
                               Margin="20,-3,0,0" x:Name="recordingTimerTBlock"
                               HorizontalAlignment="Left" VerticalAlignment="Top"/>

                </Grid>

                <StackPanel Grid.Row="1" Margin="20,20">

                    <ComboBox Margin="0,20,0,0" Width="150"
                              HorizontalAlignment="Left" SelectedIndex="0">
                        <ComboBoxItem Content="raw .wav"/>
                        <ComboBoxItem Content="compressed .mp3"/>
                    </ComboBox>

                    <StackPanel Margin="0,15,0,0" Orientation="Horizontal">

                        <TextBlock Foreground="{DynamicResource Light1}"
                                   Text="> "
                                   Margin="0,0,0,0" FontWeight="Bold"/>

                        <TextBlock Foreground="{DynamicResource Light1}"
                                   x:Name="pathTBox"
                                   MouseLeftButtonDown="PathTBox_MouseLeftButtonDown"
                                   Text="{Binding FilePath, RelativeSource={RelativeSource AncestorType=Window}}"
                                   FontWeight="Thin"/>

                    </StackPanel>

                </StackPanel>

                <WrapPanel Grid.Row="1" Margin="20,10" VerticalAlignment="Bottom">

                    <Button Content="Start" Width="70" Margin="0,0,5,0"
                            Style="{DynamicResource DarkButton}"
                            Background="#FF461C1C"
                            Click="RecordButton_Click"/>

                    <Button Content="Stop" Width="70" Margin="0,0,30,0"
                            Style="{DynamicResource DarkButton}"
                            Background="#FF212140"
                            Click="StopRecordingButton_Click"/>

                    <Button Content="Open" Width="70" Margin="0,0,5,0"
                            Style="{DynamicResource DarkButton}"
                            Visibility="Collapsed"/>

                </WrapPanel>

            </Grid>



            <Grid Grid.Column="1" Background="{DynamicResource Dark1}"
                  Margin="5">

                <TextBlock Margin="20" Text="MP3 MANIFEST EDITOR"
                           Foreground="White" FontSize="30"/>

            </Grid>

        </Grid>

    </Grid>

</Window>
