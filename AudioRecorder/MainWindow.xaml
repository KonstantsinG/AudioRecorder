<Window x:Class="AudioRecorder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AudioRecorder"
        mc:Ignorable="d" WindowStyle="None"
        Title="AudioRecorder" Height="540" Width="960"
        Background="{DynamicResource Accent}">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="35" ResizeBorderThickness="6"
                      GlassFrameThickness="5" UseAeroCaptionButtons="True"
                      CornerRadius="10"/>
    </WindowChrome.WindowChrome>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Rectangle Grid.RowSpan="2" Margin="2" Fill="{DynamicResource Dark1}"
                   RadiusX="5" RadiusY="5"/>

        <Grid Grid.Row="0">

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="10,0">

                <Ellipse Height="10" Width="10" Fill="LawnGreen" Margin="5,0"
                         WindowChrome.IsHitTestVisibleInChrome="True"/>

                <Ellipse Height="10" Width="10" Fill="Yellow" Margin="5,0"
                         WindowChrome.IsHitTestVisibleInChrome="True"/>

                <Ellipse Height="10" Width="10" Fill="OrangeRed" Margin="5,0"
                         WindowChrome.IsHitTestVisibleInChrome="True"/>

            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                        Margin="15,0" VerticalAlignment="Center">

                <Ellipse Height="5" Width="5" Fill="White" Margin="5"/>
                
                <TextBlock Text="AudioRecorder" Foreground="{DynamicResource Light0}"
                           FontWeight="Light"/>

            </StackPanel>

        </Grid>

    </Grid>
    
</Window>
