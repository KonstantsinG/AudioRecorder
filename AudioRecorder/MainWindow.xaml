<Window x:Class="AudioRecorder.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AudioRecorder"
        mc:Ignorable="d" WindowStyle="None"
        Title="AudioRecorder" Height="540" Width="960"
        Background="{DynamicResource Accent}"
        Loaded="Window_Loaded">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="30" ResizeBorderThickness="6"
                      GlassFrameThickness="5" UseAeroCaptionButtons="True"
                      CornerRadius="10"/>
    </WindowChrome.WindowChrome>

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Rectangle Grid.RowSpan="2" Margin="2" Fill="{DynamicResource Dark1}"
                   RadiusX="5" RadiusY="5"/>

        <Grid Grid.Row="0" VerticalAlignment="Center">

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="10,0">

                <Ellipse Height="10" Width="10" Fill="LawnGreen" Margin="5,0"
                         WindowChrome.IsHitTestVisibleInChrome="True"
                         MouseLeftButtonDown="GreenCircle_MouseLeftButtonDown"/>

                <Ellipse Height="10" Width="10" Fill="Yellow" Margin="5,0"
                         WindowChrome.IsHitTestVisibleInChrome="True"
                         MouseLeftButtonDown="YellowCircle_MouseLeftButtonDown"/>

                <Ellipse Height="10" Width="10" Fill="OrangeRed" Margin="5,0"
                         WindowChrome.IsHitTestVisibleInChrome="True"
                         MouseLeftButtonDown="RedCircle_MouseLeftButtonDown"/>

            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left"
                        Margin="15,0" VerticalAlignment="Center">

                <Ellipse Height="5" Width="5" Fill="White" Margin="5"/>
                
                <TextBlock Text="AudioRecorder" Foreground="{DynamicResource Light0}"
                           FontWeight="Light"/>

            </StackPanel>

        </Grid>

        <Grid Grid.Row="1" Background="{DynamicResource Dark2}" Margin="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="370"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Background="{DynamicResource Dark1}"
                  Margin="5">

                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="1*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="5*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <Grid Grid.Column="0">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <StackPanel Margin="25,0,0,0" VerticalAlignment="Bottom"
                                    Orientation="Horizontal">

                            <TextBlock Foreground="{DynamicResource Light1}"
                                       Text="Available devices"  FontWeight="Light"/>

                            <Image Source="/Icons/refresh.png"
                                   Width="15" Height="15" Margin="10,0"/>

                        </StackPanel>

                        <Rectangle Width="Auto" Height="Auto" Margin="10,5,5,0"
                                   Fill="{DynamicResource Dark1}" StrokeThickness="2"
                                   Stroke="{DynamicResource Dark3}"
                                   RadiusX="5" RadiusY="5" Grid.Row="1"/>

                        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Hidden">
                            <StackPanel Margin="20,15,15,0">

                                <local:DeviceControl IsSpeaker="True" DeviceName="Realtek Speakers" Volume="100%"/>
                                <local:DeviceControl IsSpeaker="False" DeviceName="Sony headphones microphone" Volume="20%"/>
                                <local:DeviceControl IsHighlighted="True"/>

                            </StackPanel>
                        </ScrollViewer>

                    </Grid>

                    <Grid Grid.Column="1">

                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition/>
                        </Grid.RowDefinitions>

                        <StackPanel Margin="25,0,0,0" VerticalAlignment="Bottom"
                                    Orientation="Horizontal">

                            <TextBlock Foreground="{DynamicResource Light1}"
                                       Text="Running processes"  FontWeight="Light"/>

                            <Image Source="/Icons/refresh.png"
                                   Width="15" Height="15" Margin="10,0"/>

                        </StackPanel>

                        <Rectangle Width="Auto" Height="Auto" Margin="5,5,10,0"
                                   Fill="{DynamicResource Dark1}" StrokeThickness="2"
                                   Stroke="{DynamicResource Dark3}"
                                   RadiusX="5" RadiusY="5" Grid.Row="1"/>

                    </Grid>

                </Grid>

                <StackPanel Grid.Row="1" Margin="20,10">

                    <Grid>

                        <Ellipse Height="12" Width="12" Stroke="White"
                                 HorizontalAlignment="Left" StrokeThickness="1"/>

                        <Ellipse Height="4" Width="4" Fill="White"
                                 HorizontalAlignment="Left" Margin="4,0,0,0"/>

                        <TextBlock Foreground="{DynamicResource Light1}"
                                   Text="Ready"  FontWeight="Light"
                                   Margin="20,0,0,0"/>

                    </Grid>

                    <ComboBox Margin="0,25,0,0" Width="150"
                              HorizontalAlignment="Left" SelectedIndex="0">
                        <ComboBoxItem Content="raw .wav"/>
                        <ComboBoxItem Content="compressed .mp3"/>
                    </ComboBox>

                    <TextBlock Foreground="{DynamicResource Light1}"
                               Text="> C:\Documents\Recordings\new_recording.wav"
                               Margin="0,10,0,0" FontWeight="Thin"/>

                </StackPanel>

                <WrapPanel Grid.Row="1" Margin="20,10" VerticalAlignment="Bottom">

                    <Button Content="Start" Width="70" Margin="0,0,5,0"
                            Background="#FF9AA0FD" FontWeight="Medium"/>

                    <Button Content="Stop" Width="70" Margin="0,0,50,0"
                            Background="#FFE48585" FontWeight="Medium"/>

                    <Button Content="Open" Width="70" Margin="0,0,5,0"
                            Background="#FFC3AB69" FontWeight="Medium"/>

                </WrapPanel>

            </Grid>



            <Grid Grid.Column="1" Background="{DynamicResource Dark1}"
                  Margin="5">

                <TextBlock Margin="20" Text="MP3 MANIFEST EDITOR"
                           Foreground="White" FontSize="30"/>

            </Grid>
            
        </Grid>

    </Grid>
    
</Window>
