<UserControl x:Class="AudioRecorder.DeviceControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:AudioRecorder"
             mc:Ignorable="d"  MinHeight="40" Cursor="Hand"
             d:DesignHeight="40" d:DesignWidth="400">
    
    <Grid Margin="0,0,0,5">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="50"/>
            <ColumnDefinition/>
            <ColumnDefinition Width="60"/>
        </Grid.ColumnDefinitions>

        <Rectangle Grid.ColumnSpan="3" Fill="{DynamicResource Dark2}"
                   StrokeThickness="1" RadiusX="4" RadiusY="4"
                   Stroke="{DynamicResource Light2}" x:Name="bgRect"
                   Width="Auto" Height="Auto" IsHitTestVisible="False"/>

        <Image Source="{Binding DeviceIconPath, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}"
               Width="20" Height="20" IsHitTestVisible="False"/>

        <TextBlock Grid.Column="1" Foreground="{DynamicResource Light0}"
                   Text="{Binding DeviceName, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}"
                   VerticalAlignment="Center" FontWeight="Light" FontSize="12"
                   IsHitTestVisible="False"/>

        <Image Source="/Icons/volume.png" Width="15" Height="15"
               Grid.Column="2" HorizontalAlignment="Left"
               IsHitTestVisible="False"/>

        <TextBlock Grid.Column="2" Foreground="{DynamicResource Light0}"
                   VerticalAlignment="Center" FontWeight="Light" FontSize="12"
                   Margin="22,0,0,0" IsHitTestVisible="False"
                   Text="{Binding Volume, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}"/>

    </Grid>
    
</UserControl>
