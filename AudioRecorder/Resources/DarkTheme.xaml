<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <SolidColorBrush x:Key="Dark0" Color="#FF0C0C0C"/>
    <SolidColorBrush x:Key="Dark1" Color="#FF1C1C1C"/>
    <SolidColorBrush x:Key="Dark2" Color="#FF262626"/>
    <SolidColorBrush x:Key="Dark3" Color="#FF333333"/>

    <SolidColorBrush x:Key="Light0" Color="#FFF3F3F3"/>
    <SolidColorBrush x:Key="Light1" Color="#FFCCCCCC"/>
    <SolidColorBrush x:Key="Light2" Color="#FF999999"/>

    <SolidColorBrush x:Key="Accent" Color="#FF9184EE"/>

</ResourceDictionary>